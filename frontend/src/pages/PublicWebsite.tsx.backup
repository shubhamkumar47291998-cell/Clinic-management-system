  const posts = [
    { title: 'Managing Diabetes in Monsoon Season', author: 'Dr. Anisha Natekar', date: 'June 2026', tag: 'Internal Medicine', excerpt: 'Monsoon brings humidity that can complicate blood sugar management. Here are evidence-based strategies to keep your levels stable this season.' },
