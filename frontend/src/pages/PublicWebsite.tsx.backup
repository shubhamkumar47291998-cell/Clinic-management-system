// ─── 1. HOME ──────────────────────────────────────────────────────────────────

export const PublicHome: React.FC = () => {
  const [doctors, setDoctors] = useState<any[]>([]);
  const [loadingDocs, setLoadingDocs] = useState(true);
  const clinicId = '11111111-1111-1111-1111-111111111111';
  const [selectedDocId, setSelectedDocId] = useState('');
  const [availableDays, setAvailableDays] = useState<Date[]>([]);
  const [selectedDateStr, setSelectedDateStr] = useState('');
  const [availableSlots, setAvailableSlots] = useState<{ start: string; end: string }[]>([]);
  const [selectedSlot, setSelectedSlot] = useState<{ start: string; end: string } | null>(null);
  const [name, setName] = useState('');
  const [phone, setPhone] = useState('');
  const [dob, setDob] = useState('');
  const [gender, setGender] = useState('Male');
  const [notes, setNotes] = useState('');
  const [bookingLoading, setBookingLoading] = useState(false);
  const [bookingSuccess, setBookingSuccess] = useState(false);
  const [bookingError, setBookingError] = useState('');
  const bookingRef = React.useRef<HTMLDivElement>(null);

  const smoothScrollToBooking = () => bookingRef.current?.scrollIntoView({ behavior: 'smooth', block: 'start' });

  useEffect(() => {
    document.title = 'Aura Healthcare Network – Certified Medical Excellence';
    const days: Date[] = [];
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    for (let i = 0; i < 7; i++) {
      const d = new Date(today);
      d.setDate(today.getDate() + i);
      days.push(d);
    }
    setAvailableDays(days);

    const fetchDocs = async () => {
      setLoadingDocs(true);
      try {
        const { data } = await supabase
          .from('profiles')
          .select('id, name, specialization, qualifications, designation, department_id, departments!department_id(name), doctor_schedules(day_of_week, start_time, end_time, is_active)')
          .eq('clinic_id', clinicId)
          .eq('role', 'doctor')
          .eq('is_active', true);
        setDoctors(data || []);
      } catch (err) {
        console.error(err);
      } finally {
        setLoadingDocs(false);
      }
    };
    fetchDocs();
  }, []);

  const fetchSlots = useCallback(async () => {
    if (!selectedDocId || !selectedDateStr) return;
    setAvailableSlots([]);
    setSelectedSlot(null);
    try {
      // IST-safe weekday calculation
      const weekday = getLocalDayOfWeek(selectedDateStr);
      const { data: scheds } = await supabase
        .from('doctor_schedules')
        .select('day_of_week, start_time, end_time, slot_duration_minutes')
        .eq('doctor_id', selectedDocId)
        .eq('is_active', true)
        .eq('day_of_week', weekday);
      if (!scheds || scheds.length === 0) return;
      const daySched = scheds[0];
      const slots: { start: string; end: string }[] = [];
      const [sh, sm] = daySched.start_time.split(':').map(Number);
      const [eh, em] = daySched.end_time.split(':').map(Number);
      const duration = daySched.slot_duration_minutes;
      // Generate slots without Date object (pure arithmetic)
      let curH = sh, curM = sm;
      while (curH * 60 + curM + duration <= eh * 60 + em) {
        const nxtTotalMin = curH * 60 + curM + duration;
        const nxtH = Math.floor(nxtTotalMin / 60), nxtM = nxtTotalMin % 60;
        slots.push({
          start: `${String(curH).padStart(2,'0')}:${String(curM).padStart(2,'0')}`,
          end: `${String(nxtH).padStart(2,'0')}:${String(nxtM).padStart(2,'0')}`,
        });
        curH = nxtH; curM = nxtM;
      }
      // Fetch booked slots using IST-correct ISO range
      const dayStart = buildISTIso(selectedDateStr, `${String(sh).padStart(2,'0')}:00`);
      const dayEnd = buildISTIso(selectedDateStr, `${String(eh).padStart(2,'0')}:59`);
      const { data: booked } = await supabase
        .from('appointments')
        .select('slot_start')
        .eq('doctor_id', selectedDocId)
        .neq('status', 'cancelled')
        .gte('slot_start', dayStart)
        .lte('slot_start', dayEnd);
      const bookedSet = new Set((booked || []).map((b: any) => new Date(b.slot_start).toISOString()));
      setAvailableSlots(slots.filter((s) => {
        const slotIso = buildISTIso(selectedDateStr, s.start);
        return !bookedSet.has(new Date(slotIso).toISOString());
      }));
    } catch (err) {
      console.error(err);
    }
  }, [selectedDocId, selectedDateStr]);

  useEffect(() => { fetchSlots(); }, [fetchSlots]);

  const handleBookingSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!selectedDocId || !selectedSlot || !name.trim() || !phone.trim()) {
      setBookingError('Please select doctor, date, slot and fill in your name & phone.');
      return;
    }
    setBookingLoading(true);
    setBookingError('');
    try {
      const startIso = buildISTIso(selectedDateStr, selectedSlot.start);
      const endIso = buildISTIso(selectedDateStr, selectedSlot.end);
      const { data, error } = await supabase.rpc('book_public_appointment', {
        p_clinic_id: clinicId,
        p_doctor_id: selectedDocId,
        p_patient_name: name.trim(),
        p_patient_phone: phone.trim(),
        p_patient_dob: dob || null,
        p_patient_gender: gender,
        p_slot_start: startIso,
        p_slot_end: endIso,
        p_notes: notes.trim() || null,
        p_payment_mode: 'Cash',
        p_payment_status: 'Paid',
        p_transaction_id: `CASH-${Date.now()}`,
        p_amount: 590,
        p_paid_amount: 590,
        p_balance_amount: 0,
        p_payment_details: { mode: 'Cash – Home Page Quick Book' },
      });
      if (error) throw error;
      if (data && !data.success) throw new Error(data.message);
      setBookingSuccess(true);
      setName(''); setPhone(''); setDob(''); setNotes('');
    } catch (err: any) {
      setBookingError(err.message || 'Booking failed. Please try again.');
    } finally {
      setBookingLoading(false);
    }
  };

  return (
    <div>
      {/* Hero */}
      <section style={{ background: 'linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%)', color: '#fff', padding: '6rem 2rem 5rem', position: 'relative', overflow: 'hidden' }}>
        <div style={{ position: 'absolute', inset: 0, backgroundImage: 'radial-gradient(circle at 20% 50%, rgba(99,102,241,0.15) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(167,139,250,0.1) 0%, transparent 50%)' }} />
        <div style={{ maxWidth: '1280px', margin: '0 auto', position: 'relative', display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(300px, 1fr))', gap: '4rem', alignItems: 'center' }}>
          <div>
            <div style={{ display: 'inline-flex', alignItems: 'center', gap: '0.5rem', backgroundColor: 'rgba(99,102,241,0.2)', border: '1px solid rgba(99,102,241,0.4)', borderRadius: '50px', padding: '0.4rem 1rem', fontSize: '0.8rem', fontWeight: 600, marginBottom: '1.5rem', color: '#c7d2fe' }}>
              <div style={{ width: '8px', height: '8px', borderRadius: '50%', backgroundColor: '#4ade80' }} />
              NABH Accredited · ISO 9001:2015 Certified
            </div>
            <h1 style={{ fontFamily: 'var(--font-heading)', fontSize: 'clamp(2rem, 5vw, 3.25rem)', fontWeight: 900, lineHeight: 1.15, letterSpacing: '-1px', marginBottom: '1.25rem' }}>
              Premium Healthcare,<br />
              <span style={{ background: 'linear-gradient(90deg, #818cf8, #a78bfa)', WebkitBackgroundClip: 'text', WebkitTextFillColor: 'transparent' }}>
                Right Here in Goa
              </span>
            </h1>
            <p style={{ fontSize: '1.05rem', color: '#cbd5e1', lineHeight: '1.7', maxWidth: '520px', marginBottom: '2rem' }}>
              Consult certified specialists in Internal Medicine, Cardiology, Pediatrics & more. Book an appointment online in under 2 minutes.
            </p>
            <div style={{ display: 'flex', gap: '1rem', flexWrap: 'wrap' }}>
              <button onClick={smoothScrollToBooking} className="btn btn-primary" style={{ padding: '0.75rem 1.75rem', fontSize: '1rem', fontWeight: 700, border: 'none', cursor: 'pointer', display: 'flex', alignItems: 'center', gap: '0.5rem' }}>
                Book Appointment <ArrowRight size={18} />
              </button>
              <Link to="/doctors" className="btn btn-secondary" style={{ padding: '0.75rem 1.75rem', fontSize: '1rem', fontWeight: 700, textDecoration: 'none', backgroundColor: 'rgba(255,255,255,0.08)', color: '#fff', borderColor: 'rgba(255,255,255,0.2)' }}>
                View Doctors
              </Link>
            </div>
          </div>
          <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '1rem' }}>
            {[
              { icon: Users, label: '13,000+ Patients', sub: 'Across all departments' },
              { icon: AwardIcon, label: 'NABH Certified', sub: 'Accredited standards' },
              { icon: Clock, label: '24×7 Emergency', sub: 'Always available' },
              { icon: Shield, label: 'ISO 9001:2015', sub: 'Quality assured' },
            ].map(({ icon: Icon, label, sub }, i) => (
              <div key={i} style={{ backgroundColor: 'rgba(255,255,255,0.05)', border: '1px solid rgba(255,255,255,0.1)', borderRadius: '16px', padding: '1.25rem', backdropFilter: 'blur(8px)' }}>
                <div style={{ width: '40px', height: '40px', borderRadius: '12px', backgroundColor: 'rgba(99,102,241,0.2)', display: 'flex', alignItems: 'center', justifyContent: 'center', marginBottom: '0.75rem' }}>
                  <Icon size={20} color="#818cf8" />
                </div>
                <div style={{ fontWeight: 700, fontSize: '0.95rem', color: '#fff' }}>{label}</div>
                <div style={{ fontSize: '0.8rem', color: '#94a3b8', marginTop: '0.2rem' }}>{sub}</div>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* Quick Doctor Preview */}
      <section style={{ padding: '5rem 2rem', backgroundColor: 'var(--bg-primary)' }}>
        <div style={{ maxWidth: '1280px', margin: '0 auto' }}>
          <div style={{ textAlign: 'center', marginBottom: '3.5rem' }}>
            <span style={{ color: 'var(--accent-primary)', fontWeight: 700, textTransform: 'uppercase', letterSpacing: '1.5px', fontSize: '0.8rem' }}>MEET OUR SPECIALISTS</span>
            <h2 style={{ fontFamily: 'var(--font-heading)', fontSize: '2.25rem', fontWeight: 800, marginTop: '0.5rem', letterSpacing: '-0.5px' }}>Certified Doctors Panel</h2>
          </div>

          {loadingDocs ? (
            <div style={{ textAlign: 'center', padding: '3rem', color: 'var(--text-muted)' }}>Loading specialists…</div>
          ) : doctors.length === 0 ? (
            <div style={{ textAlign: 'center', padding: '3rem', color: 'var(--text-muted)' }}>No doctors found.</div>
          ) : (
            <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(300px, 1fr))', gap: '2rem' }}>
              {doctors.map((doc) => {
                const meta = getDoctorMeta(doc.name);
                const docName = doc.name.startsWith('Dr') ? doc.name : `Dr. ${doc.name}`;
                return (
                  <div
                    key={doc.id}
                    className="dashboard-card"
                    style={{ padding: '1.75rem', borderRadius: '20px', border: '1px solid var(--border-color)', display: 'flex', flexDirection: 'column', gap: '1rem' }}
                  >
                    <div style={{ display: 'flex', gap: '1rem', alignItems: 'flex-start' }}>
                      <img src={meta.photo} alt={docName} style={{ width: '72px', height: '72px', borderRadius: '14px', objectFit: 'cover', border: '2px solid var(--border-color)' }} onError={(e) => { (e.target as HTMLImageElement).style.display = 'none'; }} />
                      <div>
                        <h3 style={{ fontSize: '1.1rem', fontWeight: 800, margin: 0 }}>{docName}</h3>
                        <span style={{ fontSize: '0.8rem', color: 'var(--accent-primary)', fontWeight: 600, display: 'block', marginTop: '0.2rem' }}>{doc.designation || 'Consultant'}</span>
                        <span style={{ fontSize: '0.75rem', color: 'var(--text-muted)', display: 'block' }}>{doc.specialization || 'Internal Medicine'}</span>
                      </div>
                    </div>
                    <div style={{ display: 'flex', gap: '0.4rem', flexWrap: 'wrap' }}>
                      <span style={{ padding: '0.2rem 0.55rem', borderRadius: '50px', fontSize: '0.72rem', fontWeight: 700, backgroundColor: 'rgba(79,70,229,0.07)', color: 'var(--accent-primary)' }}>⭐ {meta.rating}</span>
                      <span style={{ padding: '0.2rem 0.55rem', borderRadius: '50px', fontSize: '0.72rem', fontWeight: 700, backgroundColor: 'rgba(16,185,129,0.07)', color: '#059669' }}>🏥 {meta.experience}+ yrs</span>
                      <span style={{ padding: '0.2rem 0.55rem', borderRadius: '50px', fontSize: '0.72rem', fontWeight: 700, backgroundColor: 'rgba(217,119,6,0.07)', color: '#d97706' }}>💰 ₹{meta.fee}</span>
                    </div>
                    <button onClick={smoothScrollToBooking} className="btn btn-primary" style={{ fontSize: '0.85rem', padding: '0.5rem', border: 'none', cursor: 'pointer' }}>
                      Book Appointment
                    </button>
                  </div>
                );
              })}
            </div>
          )}

          <div style={{ textAlign: 'center', marginTop: '2.5rem' }}>
            <Link to="/doctors" style={{ display: 'inline-flex', alignItems: 'center', gap: '0.5rem', color: 'var(--accent-primary)', textDecoration: 'none', fontWeight: 700, fontSize: '0.95rem' }}>
              View All Doctors <ChevronRight size={18} />
            </Link>
          </div>
        </div>
      </section>

      {/* Booking Form */}
      <section ref={bookingRef} id="book" style={{ padding: '5rem 2rem', backgroundColor: 'var(--bg-card)' }}>
        <div style={{ maxWidth: '900px', margin: '0 auto' }}>
          <div style={{ textAlign: 'center', marginBottom: '3rem' }}>
            <span style={{ color: 'var(--accent-primary)', fontWeight: 700, textTransform: 'uppercase', letterSpacing: '1.5px', fontSize: '0.8rem' }}>ONLINE BOOKING</span>
            <h2 style={{ fontFamily: 'var(--font-heading)', fontSize: '2.25rem', fontWeight: 800, marginTop: '0.5rem' }}>Book Your Consultation</h2>
          </div>

          {bookingSuccess ? (
            <div style={{ textAlign: 'center', padding: '3rem', border: '1px solid var(--border-color)', borderRadius: '24px', backgroundColor: 'var(--bg-primary)' }}>
              <div style={{ width: '64px', height: '64px', borderRadius: '50%', backgroundColor: '#ecfdf5', color: '#10b981', display: 'flex', alignItems: 'center', justifyContent: 'center', margin: '0 auto 1rem' }}><Check size={32} /></div>
              <h3 style={{ fontSize: '1.5rem', fontWeight: 800 }}>Appointment Confirmed!</h3>
              <p style={{ color: 'var(--text-secondary)', marginTop: '0.5rem' }}>Your booking is confirmed. You will receive a confirmation SMS shortly.</p>
              <button onClick={() => setBookingSuccess(false)} className="btn btn-primary" style={{ marginTop: '1.5rem', border: 'none', cursor: 'pointer' }}>Book Another</button>
            </div>
          ) : (
            <form onSubmit={handleBookingSubmit} style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(280px, 1fr))', gap: '1.5rem', backgroundColor: 'var(--bg-primary)', padding: '2.5rem', borderRadius: '24px', border: '1px solid var(--border-color)' }}>
              {bookingError && <div className="alert alert-danger" style={{ gridColumn: '1 / -1' }}>{bookingError}</div>}

              <div className="form-group" style={{ gridColumn: '1 / -1' }}>
                <label>Select Doctor *</label>
                <select value={selectedDocId} onChange={(e) => { setSelectedDocId(e.target.value); setSelectedDateStr(''); setAvailableSlots([]); setSelectedSlot(null); }}
                  style={{ width: '100%', padding: '0.75rem', border: '1px solid var(--border-color)', borderRadius: 'var(--radius-sm)', backgroundColor: 'var(--bg-card)', color: 'var(--text-primary)', outline: 'none', marginTop: '0.5rem' }}>
                  <option value="">-- Select Specialist --</option>
                  {doctors.map((d) => <option key={d.id} value={d.id}>{d.name.startsWith('Dr') ? d.name : `Dr. ${d.name}`} – {d.specialization || 'Consultant'}</option>)}
                </select>
              </div>

              <div className="form-group">
                <label>Select Date *</label>
                <div style={{ display: 'grid', gridTemplateColumns: 'repeat(4, 1fr)', gap: '0.5rem', marginTop: '0.5rem' }}>
                  {availableDays.map((d, idx) => {
                    const dateStr = toLocalDateStr(d);
                    const isSel = selectedDateStr === dateStr;
                    return (
                      <button key={idx} type="button" onClick={() => setSelectedDateStr(dateStr)} style={{ padding: '0.5rem 0', borderRadius: '10px', border: isSel ? '1px solid var(--accent-primary)' : '1px solid var(--border-color)', backgroundColor: isSel ? 'var(--accent-primary)' : 'var(--bg-card)', color: isSel ? '#fff' : 'var(--text-primary)', cursor: 'pointer', textAlign: 'center', fontSize: '0.75rem', fontWeight: 700 }}>
                        <div style={{ textTransform: 'uppercase', fontSize: '0.62rem', opacity: 0.7 }}>{d.toLocaleDateString(undefined, { weekday: 'short' })}</div>
                        <div style={{ fontSize: '1rem', marginTop: '0.1rem' }}>{d.getDate()}</div>
                      </button>
                    );
                  })}
                </div>
              </div>

              <div className="form-group">
                <label>Time Slot *</label>
                {!selectedDocId || !selectedDateStr ? (
                  <p style={{ fontSize: '0.8rem', color: 'var(--text-muted)', marginTop: '0.5rem', fontStyle: 'italic' }}>Select doctor & date first.</p>
                ) : availableSlots.length === 0 ? (
                  <p style={{ fontSize: '0.8rem', color: 'var(--text-muted)', marginTop: '0.5rem', fontStyle: 'italic' }}>No slots available today.</p>
                ) : (
                  <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: '0.4rem', marginTop: '0.5rem' }}>
                    {availableSlots.map((slot, i) => {
                      const isSel = selectedSlot?.start === slot.start;
                      return <button key={i} type="button" onClick={() => setSelectedSlot(slot)} style={{ padding: '0.45rem 0', borderRadius: '8px', border: isSel ? '1px solid var(--accent-primary)' : '1px solid var(--border-color)', backgroundColor: isSel ? 'var(--accent-primary)' : 'var(--bg-card)', color: isSel ? '#fff' : 'var(--text-primary)', cursor: 'pointer', fontSize: '0.8rem', fontWeight: 700 }}>{slot.start}</button>;
                    })}
                  </div>
                )}
              </div>

              <AuthInput label="Patient Name *" icon={User} type="text" placeholder="Full Name" value={name} onChange={(e) => setName(e.target.value)} disabled={bookingLoading} required />
              <AuthInput label="Mobile Number *" icon={Phone} type="tel" placeholder="9546650878" value={phone} onChange={(e) => setPhone(e.target.value)} disabled={bookingLoading} required />
              <AuthInput label="Date of Birth" icon={Calendar} type="date" value={dob} onChange={(e) => setDob(e.target.value)} disabled={bookingLoading} />

              <div className="form-group">
                <label>Gender</label>
                <select value={gender} onChange={(e) => setGender(e.target.value)} disabled={bookingLoading} style={{ width: '100%', padding: '0.75rem', border: '1px solid var(--border-color)', borderRadius: 'var(--radius-sm)', backgroundColor: 'var(--bg-card)', color: 'var(--text-primary)', outline: 'none', marginTop: '0.5rem' }}>
                  <option value="Male">Male</option>
                  <option value="Female">Female</option>
                  <option value="Other">Other</option>
                </select>
              </div>

              <div className="form-group" style={{ gridColumn: '1 / -1' }}>
                <label>Reason for Visit</label>
                <textarea placeholder="Describe your symptoms…" value={notes} onChange={(e) => setNotes(e.target.value)} rows={2} disabled={bookingLoading} style={{ width: '100%', padding: '0.75rem', border: '1px solid var(--border-color)', borderRadius: 'var(--radius-sm)', backgroundColor: 'var(--bg-card)', color: 'var(--text-primary)', outline: 'none', resize: 'vertical', marginTop: '0.5rem' }} />
              </div>

              <div style={{ gridColumn: '1 / -1' }}>
                <AuthButton type="submit" loading={bookingLoading} loadingText="Confirming…">Confirm Appointment (₹590 incl. GST)</AuthButton>
              </div>
            </form>
          )}
        </div>
      </section>
    </div>
  );
};

// ─── 2. ABOUT ─────────────────────────────────────────────────────────────────

export const PublicAbout: React.FC = () => {
  useEffect(() => { document.title = 'About Us – Aura Healthcare Clinics'; }, []);
  return (
    <div style={{ padding: '4rem 2rem', maxWidth: '1100px', margin: '0 auto' }}>
      <div style={{ textAlign: 'center', marginBottom: '3.5rem' }}>
        <span style={{ color: 'var(--accent-primary)', fontWeight: 700, textTransform: 'uppercase', letterSpacing: '1px', fontSize: '0.85rem' }}>WHO WE ARE</span>
        <h1 style={{ fontFamily: 'var(--font-heading)', fontSize: '2.5rem', fontWeight: 800, marginTop: '0.5rem' }}>About Aura Health Clinic</h1>
      </div>
      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(300px, 1fr))', gap: '3rem', alignItems: 'start' }}>
        <div>
          <p style={{ fontSize: '1rem', lineHeight: '1.8', color: 'var(--text-secondary)', marginBottom: '1.5rem' }}>
            Founded in 2014, Aura Health Clinic is a NABH-accredited multi-specialty clinic serving the Sankhalim community in North Goa. We are committed to delivering compassionate, world-class healthcare that is accessible and affordable for every patient.
          </p>
          <p style={{ fontSize: '1rem', lineHeight: '1.8', color: 'var(--text-secondary)' }}>
            Our team of certified specialists brings together expertise in Internal Medicine, Cardiology, Pediatrics, and more — supported by an ISO 9001:2015 certified infrastructure and state-of-the-art diagnostic equipment.
          </p>
        </div>
        <div style={{ display: 'flex', flexDirection: 'column', gap: '1rem' }}>
          {[
            { icon: Shield, title: 'NABH Accredited', desc: 'Certified under Indian National Standards for clinical safety and quality.' },
            { icon: AwardIcon, title: 'ISO 9001:2015', desc: 'Quality management certified across all departments.' },
            { icon: Users, title: '13,000+ Patients', desc: 'Trusted by thousands across North Goa and beyond.' },
            { icon: Clock, title: '24×7 Emergency', desc: 'Round-the-clock emergency care with trauma-ready staff.' },
          ].map(({ icon: Icon, title, desc }, i) => (
            <div key={i} className="dashboard-card" style={{ padding: '1.25rem', display: 'flex', gap: '1rem', alignItems: 'flex-start', borderRadius: '14px' }}>
              <div style={{ width: '40px', height: '40px', borderRadius: '10px', backgroundColor: 'var(--accent-light)', display: 'flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0 }}>
                <Icon size={20} color="var(--accent-primary)" />
              </div>
              <div>
                <strong style={{ display: 'block', fontSize: '0.95rem' }}>{title}</strong>
                <span style={{ fontSize: '0.85rem', color: 'var(--text-muted)' }}>{desc}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
};

// ─── 3. DOCTORS DIRECTORY ─────────────────────────────────────────────────────

export const PublicDoctors: React.FC = () => {
  const [doctors, setDoctors] = useState<any[]>([]);
  const [search, setSearch] = useState('');
  const [deptFilter, setDeptFilter] = useState('');
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    document.title = 'Our Specialists – Aura Healthcare Clinics';
    const fetchDoctors = async () => {
      setLoading(true);
      try {
        const { data } = await supabase
          .from('profiles')
          .select('id, name, specialization, qualifications, designation, department_id, departments!department_id(name), doctor_schedules(day_of_week, start_time, end_time, is_active)')
          .eq('clinic_id', '11111111-1111-1111-1111-111111111111')
          .eq('role', 'doctor')
          .eq('is_active', true);
        setDoctors(data || []);
      } catch (err) {
        console.error('Error fetching doctors:', err);
      } finally {
        setLoading(false);
      }
    };
    fetchDoctors();
  }, []);

  const filtered = doctors.filter((doc) => {
    const q = search.toLowerCase();
    const matchSearch = !q || doc.name.toLowerCase().includes(q) || (doc.specialization && doc.specialization.toLowerCase().includes(q));
    const matchDept = !deptFilter || doc.departments?.name === deptFilter;
    return matchSearch && matchDept;
  });

  return (
    <div style={{ padding: '4rem 2rem', maxWidth: '1280px', margin: '0 auto' }}>
      {/* Page Header */}
      <div style={{ textAlign: 'center', marginBottom: '3rem' }}>
        <span style={{ color: 'var(--accent-primary)', fontWeight: 700, textTransform: 'uppercase', letterSpacing: '1.5px', fontSize: '0.8rem' }}>CERTIFIED SPECIALISTS</span>
        <h1 style={{ fontFamily: 'var(--font-heading)', fontSize: 'clamp(2rem, 4vw, 2.75rem)', fontWeight: 800, marginTop: '0.5rem', letterSpacing: '-0.5px' }}>
          Find Your Doctor
        </h1>
        <p style={{ color: 'var(--text-muted)', marginTop: '0.5rem', maxWidth: '560px', margin: '0.75rem auto 0' }}>
          Book a consultation with our verified, NABH-certified medical specialists.
        </p>
      </div>

      {/* Filters */}
      <div style={{ display: 'flex', gap: '1rem', flexWrap: 'wrap', marginBottom: '3rem', justifyContent: 'center' }}>
        <div style={{ position: 'relative', width: '360px' }}>
          <Search size={16} style={{ position: 'absolute', left: '1rem', top: '50%', transform: 'translateY(-50%)', color: 'var(--text-muted)' }} />
          <input
            type="text"
            placeholder="Search by name or specialty…"
            value={search}
            onChange={(e) => setSearch(e.target.value)}
            style={{ width: '100%', padding: '0.75rem 0.75rem 0.75rem 2.5rem', border: '1px solid var(--border-color)', borderRadius: '12px', backgroundColor: 'var(--bg-card)', color: 'var(--text-primary)', outline: 'none' }}
          />
        </div>
        <select value={deptFilter} onChange={(e) => setDeptFilter(e.target.value)} style={{ padding: '0.75rem 1.25rem', border: '1px solid var(--border-color)', borderRadius: '12px', backgroundColor: 'var(--bg-card)', color: 'var(--text-primary)', outline: 'none', cursor: 'pointer' }}>
          <option value="">All Departments</option>
          <option value="General Medicine">General Medicine</option>
          <option value="Cardiology">Cardiology</option>
          <option value="Pediatrics">Pediatrics</option>
        </select>
      </div>

      {/* Cards */}
      {loading ? (
        <div style={{ textAlign: 'center', padding: '5rem', color: 'var(--text-muted)' }}>Loading specialists…</div>
      ) : filtered.length === 0 ? (
        <div style={{ textAlign: 'center', padding: '5rem', color: 'var(--text-muted)' }}>
          {doctors.length === 0 ? 'No specialists registered yet.' : 'No doctors match your search.'}
        </div>
      ) : (
        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(340px, 1fr))', gap: '2rem' }}>
          {filtered.map((doc) => {
            const meta = getDoctorMeta(doc.name);
            const docName = doc.name.startsWith('Dr') ? doc.name : `Dr. ${doc.name}`;
            const qual = Array.isArray(doc.qualifications) ? doc.qualifications[0] : doc.qualifications;

            return (
              <div
                key={doc.id}
                style={{
                  backgroundColor: 'var(--bg-card)',
                  borderRadius: '24px',
                  border: '1px solid var(--border-color)',
                  overflow: 'hidden',
                  boxShadow: '0 4px 24px -8px rgba(0,0,0,0.08)',
                  display: 'flex',
                  flexDirection: 'column',
                  transition: 'transform 0.25s ease, box-shadow 0.25s ease',
                }}
                onMouseEnter={(e) => { (e.currentTarget as HTMLDivElement).style.transform = 'translateY(-4px)'; (e.currentTarget as HTMLDivElement).style.boxShadow = '0 16px 40px -12px rgba(79,70,229,0.18)'; }}
                onMouseLeave={(e) => { (e.currentTarget as HTMLDivElement).style.transform = 'translateY(0)'; (e.currentTarget as HTMLDivElement).style.boxShadow = '0 4px 24px -8px rgba(0,0,0,0.08)'; }}
              >
                {/* Top accent strip */}
                <div style={{ height: '4px', background: 'linear-gradient(90deg, #4f46e5, #7c3aed)' }} />

                <div style={{ padding: '1.75rem', display: 'flex', flexDirection: 'column', gap: '1.25rem', flexGrow: 1 }}>
                  {/* Doctor header */}
                  <div style={{ display: 'flex', gap: '1.1rem', alignItems: 'flex-start' }}>
                    <div style={{ position: 'relative', flexShrink: 0 }}>
                      <img
                        src={meta.photo}
                        alt={docName}
                        style={{ width: '90px', height: '90px', borderRadius: '18px', objectFit: 'cover', border: '2px solid var(--border-color)' }}
                        onError={(e) => {
                          const el = e.target as HTMLImageElement;
                          el.style.display = 'none';
                          if (el.parentElement) {
                            el.parentElement.style.width = '90px';
                            el.parentElement.style.height = '90px';
                            el.parentElement.style.backgroundColor = 'var(--accent-light)';
                            el.parentElement.style.display = 'flex';
                            el.parentElement.style.alignItems = 'center';
                            el.parentElement.style.justifyContent = 'center';
                          }
                        }}
                      />
                      {/* Available badge */}
                      <div style={{ position: 'absolute', bottom: '-4px', right: '-4px', width: '22px', height: '22px', borderRadius: '50%', backgroundColor: '#22c55e', border: '3px solid var(--bg-card)', display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
                        <div style={{ width: '8px', height: '8px', borderRadius: '50%', backgroundColor: '#fff' }} />
                      </div>
                    </div>
                    <div style={{ minWidth: 0 }}>
                      <h3 style={{ fontSize: '1.2rem', fontWeight: 800, margin: 0, lineHeight: 1.25 }}>{docName}</h3>
                      <span style={{ fontSize: '0.82rem', color: 'var(--accent-primary)', fontWeight: 700, display: 'block', marginTop: '0.2rem' }}>
                        {doc.designation || 'Senior Consultant'}
                      </span>
                      {qual && (
                        <span style={{ fontSize: '0.76rem', color: 'var(--text-muted)', display: 'block', marginTop: '0.15rem' }}>{qual}</span>
                      )}
                    </div>
                  </div>

                  {/* Badges */}
                  <div style={{ display: 'flex', flexWrap: 'wrap', gap: '0.4rem' }}>
                    <span style={{ padding: '0.25rem 0.65rem', borderRadius: '50px', fontSize: '0.74rem', fontWeight: 700, backgroundColor: 'rgba(79,70,229,0.08)', color: 'var(--accent-primary)' }}>
                      ⭐ {meta.rating} Rating
                    </span>
                    <span style={{ padding: '0.25rem 0.65rem', borderRadius: '50px', fontSize: '0.74rem', fontWeight: 700, backgroundColor: 'rgba(16,185,129,0.08)', color: '#059669' }}>
                      🏥 {meta.experience}+ Years Exp.
                    </span>
                    <span style={{ padding: '0.25rem 0.65rem', borderRadius: '50px', fontSize: '0.74rem', fontWeight: 700, backgroundColor: 'rgba(13,148,136,0.08)', color: '#0d9488' }}>
                      🩺 {doc.specialization || 'Internal Medicine'}
                    </span>
                    <span style={{ padding: '0.25rem 0.65rem', borderRadius: '50px', fontSize: '0.74rem', fontWeight: 700, backgroundColor: 'rgba(217,119,6,0.08)', color: '#d97706' }}>
                      💰 ₹{meta.fee} Fee
                    </span>
                    <span style={{ padding: '0.25rem 0.65rem', borderRadius: '50px', fontSize: '0.74rem', fontWeight: 700, backgroundColor: 'rgba(34,197,94,0.1)', color: '#15803d' }}>
                      🟢 Available Today
                    </span>
                  </div>

                  {/* Info rows */}
                  <div style={{ fontSize: '0.84rem', color: 'var(--text-secondary)', display: 'flex', flexDirection: 'column', gap: '0.4rem', borderTop: '1px solid var(--border-color)', paddingTop: '1rem' }}>
                    <div style={{ display: 'flex', gap: '0.4rem' }}>
                      <Globe size={14} style={{ flexShrink: 0, color: 'var(--text-muted)', marginTop: '2px' }} />
                      <span><strong>Languages:</strong> {meta.languages.join(', ')}</span>
                    </div>
                    <div style={{ display: 'flex', gap: '0.4rem' }}>
                      <Users size={14} style={{ flexShrink: 0, color: 'var(--text-muted)', marginTop: '2px' }} />
                      <span><strong>Patients Treated:</strong> {meta.treated.toLocaleString()}+</span>
                    </div>
                    <div style={{ display: 'flex', gap: '0.4rem' }}>
                      <MapPin size={14} style={{ flexShrink: 0, color: 'var(--text-muted)', marginTop: '2px' }} />
                      <span>{meta.address}</span>
                    </div>
                    <div style={{ display: 'flex', gap: '0.4rem' }}>
                      <Phone size={14} style={{ flexShrink: 0, color: 'var(--text-muted)', marginTop: '2px' }} />
                      <span>+91 {meta.phone}</span>
                    </div>
                    <div style={{ display: 'flex', gap: '0.4rem' }}>
                      <Clock size={14} style={{ flexShrink: 0, color: 'var(--text-muted)', marginTop: '2px' }} />
                      <span>{getAvailabilityText(doc.doctor_schedules)}</span>
                    </div>
                  </div>

                  {/* Action buttons */}
                  <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr 1fr', gap: '0.5rem', marginTop: 'auto' }}>
                    <Link
                      to={`/doctors/${doc.id}`}
                      style={{ padding: '0.6rem 0', borderRadius: '10px', border: '1px solid var(--border-color)', backgroundColor: 'var(--bg-primary)', color: 'var(--text-primary)', fontSize: '0.78rem', fontWeight: 700, textAlign: 'center', textDecoration: 'none', display: 'flex', alignItems: 'center', justifyContent: 'center', transition: 'var(--transition-smooth)' }}
                    >
                      View Profile
                    </Link>
                    <Link
                      to={`/appointment?doctor_id=${doc.id}`}
                      style={{ padding: '0.6rem 0', borderRadius: '10px', backgroundColor: 'var(--accent-primary)', color: '#fff', fontSize: '0.78rem', fontWeight: 700, textAlign: 'center', textDecoration: 'none', display: 'flex', alignItems: 'center', justifyContent: 'center' }}
                    >
                      Book Slot
                    </Link>
                    <a
                      href={`https://wa.me/91${meta.phone}?text=Hello%2C%20I'd%20like%20to%20consult%20${encodeURIComponent(docName)}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      style={{ padding: '0.6rem 0', borderRadius: '10px', backgroundColor: '#25D366', color: '#fff', fontSize: '0.78rem', fontWeight: 700, textAlign: 'center', textDecoration: 'none', display: 'flex', alignItems: 'center', justifyContent: 'center' }}
                    >
                      WhatsApp
                    </a>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>
  );
};

// ─── 4. DOCTOR PROFILE ───────────────────────────────────────────────────────

export const PublicDoctorProfile: React.FC = () => {
  const { id } = useParams<{ id: string }>();
  const navigate = useNavigate();
  const [doctor, setDoctor] = useState<any | null>(null);
  const [loading, setLoading] = useState(true);
  const clinicId = '11111111-1111-1111-1111-111111111111';
  const [availableDays, setAvailableDays] = useState<Date[]>([]);
  const [selectedDateStr, setSelectedDateStr] = useState('');
  const [availableSlots, setAvailableSlots] = useState<{ start: string; end: string }[]>([]);
  const [selectedSlot, setSelectedSlot] = useState<{ start: string; end: string } | null>(null);
  const [name, setName] = useState('');
  const [phone, setPhone] = useState('');
  const [dob, setDob] = useState('');
  const [gender, setGender] = useState('Male');
  const [notes, setNotes] = useState('');
  const [bookingLoading, setBookingLoading] = useState(false);
  const [bookingSuccess, setBookingSuccess] = useState(false);
  const [bookingError, setBookingError] = useState('');

  useEffect(() => {
    const days: Date[] = [];
    for (let i = 0; i < 7; i++) {
      const d = new Date();
      d.setDate(d.getDate() + i);
      days.push(d);
    }
    setAvailableDays(days);

    if (!id) return;
    const fetchDoctor = async () => {
      setLoading(true);
      try {
        const { data, error } = await supabase
          .from('profiles')
          .select('id, name, specialization, qualifications, designation, department_id, departments!department_id(name), mobile, address, pin_code')
          .eq('id', id)
          .eq('role', 'doctor')
          .eq('is_active', true)
          .single();
        if (error || !data) throw new Error('Doctor not found');
        setDoctor(data);
        document.title = `${data.name.startsWith('Dr') ? '' : 'Dr. '}${data.name} – Aura Health Clinic`;
      } catch (err) {
        console.error(err);
      } finally {
        setLoading(false);
      }
    };
    fetchDoctor();
  }, [id]);

  const fetchSlots = useCallback(async () => {
    if (!id || !selectedDateStr) return;
    setAvailableSlots([]);
    setSelectedSlot(null);
    try {
      const weekday = getLocalDayOfWeek(selectedDateStr);
      const { data: scheds } = await supabase
        .from('doctor_schedules')
        .select('day_of_week, start_time, end_time, slot_duration_minutes')
        .eq('doctor_id', id)
        .eq('is_active', true)
        .eq('day_of_week', weekday);
      if (!scheds || scheds.length === 0) return;
      const s = scheds[0];
      const slots: { start: string; end: string }[] = [];
      const [sh, sm] = s.start_time.split(':').map(Number);
      const [eh, em] = s.end_time.split(':').map(Number);
      let curH = sh, curM = sm;
      while (curH * 60 + curM + s.slot_duration_minutes <= eh * 60 + em) {
        const nxtMin = curH * 60 + curM + s.slot_duration_minutes;
        const nxtH = Math.floor(nxtMin / 60), nxtM = nxtMin % 60;
        slots.push({
          start: `${String(curH).padStart(2,'0')}:${String(curM).padStart(2,'0')}`,
          end: `${String(nxtH).padStart(2,'0')}:${String(nxtM).padStart(2,'0')}`,
        });
        curH = nxtH; curM = nxtM;
      }
      const dayStart = buildISTIso(selectedDateStr, `${String(sh).padStart(2,'0')}:00`);
      const dayEnd = buildISTIso(selectedDateStr, `${String(eh).padStart(2,'0')}:59`);
      const { data: booked } = await supabase.from('appointments').select('slot_start')
        .eq('doctor_id', id).neq('status', 'cancelled')
        .gte('slot_start', dayStart).lte('slot_start', dayEnd);
      const bookedSet = new Set((booked || []).map((b: any) => new Date(b.slot_start).toISOString()));
      setAvailableSlots(slots.filter((sl) => !bookedSet.has(new Date(buildISTIso(selectedDateStr, sl.start)).toISOString())));
    } catch (err) {
      console.error(err);
    }
  }, [id, selectedDateStr]);

  useEffect(() => { fetchSlots(); }, [fetchSlots]);

  const handleBookingSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!selectedSlot || !name.trim() || !phone.trim()) {
      setBookingError('Please select a slot and fill in your name & phone.');
      return;
    }
    setBookingLoading(true);
    setBookingError('');
    try {
      const { data, error } = await supabase.rpc('book_public_appointment', {
        p_clinic_id: clinicId, p_doctor_id: id,
        p_patient_name: name.trim(), p_patient_phone: phone.trim(),
        p_patient_dob: dob || null, p_patient_gender: gender,
        p_slot_start: buildISTIso(selectedDateStr, selectedSlot.start),
        p_slot_end: buildISTIso(selectedDateStr, selectedSlot.end),
        p_notes: notes.trim() || null,
        p_payment_mode: 'Cash', p_payment_status: 'Paid',
        p_transaction_id: `CASH-${Date.now()}`,
        p_amount: 590, p_paid_amount: 590, p_balance_amount: 0,
        p_payment_details: { mode: 'Cash – Doctor Profile Quick Book' },
      });
      if (error) throw error;
      if (data && !data.success) throw new Error(data.message);
      setBookingSuccess(true);
      setName(''); setPhone(''); setDob(''); setNotes('');
    } catch (err: any) {
      setBookingError(err.message || 'Booking failed.');
    } finally {
      setBookingLoading(false);
    }
  };

  if (loading) return <div style={{ padding: '6rem 2rem', textAlign: 'center', color: 'var(--text-muted)' }}>Loading doctor profile…</div>;

  if (!doctor) {
    return (
      <div style={{ padding: '6rem 2rem', textAlign: 'center' }}>
        <h3 style={{ marginBottom: '1rem' }}>Doctor not found.</h3>
        <button onClick={() => navigate('/doctors')} className="btn btn-primary" style={{ border: 'none', cursor: 'pointer' }}>Back to Directory</button>
      </div>
    );
  }

  const meta = getDoctorMeta(doctor.name);
  const docName = doctor.name.startsWith('Dr') ? doctor.name : `Dr. ${doctor.name}`;

  return (
    <div style={{ padding: '3rem 2rem 5rem', maxWidth: '1280px', margin: '0 auto' }}>
      {/* Breadcrumb */}
      <div style={{ marginBottom: '1.75rem', fontSize: '0.85rem', color: 'var(--text-muted)', display: 'flex', alignItems: 'center', gap: '0.4rem' }}>
        <Link to="/" style={{ color: 'var(--text-muted)', textDecoration: 'none' }}>Home</Link>
        <ChevronRight size={14} />
        <Link to="/doctors" style={{ color: 'var(--text-muted)', textDecoration: 'none' }}>Doctors</Link>
        <ChevronRight size={14} />
        <span style={{ color: 'var(--text-primary)', fontWeight: 600 }}>{docName}</span>
      </div>

      {/* Profile Banner */}
      <div style={{ backgroundColor: 'var(--bg-card)', borderRadius: '24px', border: '1px solid var(--border-color)', padding: '2.5rem', display: 'flex', flexWrap: 'wrap', gap: '2rem', alignItems: 'center', marginBottom: '2.5rem', boxShadow: '0 4px 24px -8px rgba(0,0,0,0.08)' }}>
        <img src={meta.photo} alt={docName} style={{ width: '150px', height: '150px', borderRadius: '24px', objectFit: 'cover', border: '3px solid var(--border-color)', flexShrink: 0 }} onError={(e) => { (e.target as HTMLImageElement).style.display = 'none'; }} />
        <div style={{ flexGrow: 1 }}>
          <span style={{ display: 'inline-block', padding: '0.25rem 0.85rem', borderRadius: '50px', fontSize: '0.78rem', fontWeight: 700, backgroundColor: 'var(--accent-light)', color: 'var(--accent-primary)', marginBottom: '0.6rem' }}>
            {doctor.departments?.name || 'General Medicine'}
          </span>
          <h1 style={{ fontFamily: 'var(--font-heading)', fontSize: 'clamp(1.5rem, 3vw, 2.25rem)', fontWeight: 900, margin: 0, letterSpacing: '-0.5px' }}>{docName}</h1>
          <p style={{ margin: '0.3rem 0 1rem', color: 'var(--text-secondary)', fontWeight: 500 }}>{doctor.designation || 'Senior Consultant'}</p>
          <div style={{ display: 'flex', flexWrap: 'wrap', gap: '1.5rem', fontSize: '0.9rem', color: 'var(--text-secondary)' }}>
            <span>💰 Consultation: <strong style={{ color: '#0d9488' }}>₹{meta.fee}</strong></span>
            <span>👥 Patients: <strong>{meta.treated.toLocaleString()}+</strong></span>
            <span>⭐ Rating: <strong style={{ color: '#d97706' }}>{meta.rating} / 5.0</strong></span>
            <span>🏥 Experience: <strong>{meta.experience}+ Years</strong></span>
          </div>
        </div>
        <div style={{ display: 'flex', flexDirection: 'column', gap: '0.75rem' }}>
          <Link to={`/appointment?doctor_id=${doctor.id}`} className="btn btn-primary" style={{ textDecoration: 'none', textAlign: 'center', padding: '0.75rem 1.5rem', fontWeight: 700 }}>
            Book Appointment
          </Link>
          <a href={`https://wa.me/91${meta.phone}?text=Hello%2C%20I'd%20like%20to%20consult%20${encodeURIComponent(docName)}`} target="_blank" rel="noopener noreferrer" style={{ textDecoration: 'none', textAlign: 'center', padding: '0.75rem 1.5rem', borderRadius: 'var(--radius-sm)', backgroundColor: '#25D366', color: '#fff', fontWeight: 700, fontSize: '0.9rem' }}>
            WhatsApp Consult
          </a>
        </div>
      </div>

      {/* Two Column Content */}
      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(340px, 1fr))', gap: '2rem', alignItems: 'start' }}>
        {/* Left: Bio sections */}
        <div style={{ display: 'flex', flexDirection: 'column', gap: '1.5rem' }}>
          {[
            { title: 'Biography', content: meta.biography, isText: true },
          ].map(({ title, content, isText }) => (
            <div key={title} style={{ backgroundColor: 'var(--bg-card)', borderRadius: '20px', border: '1px solid var(--border-color)', padding: '1.75rem' }}>
              <h3 style={{ fontSize: '1.1rem', fontWeight: 800, marginBottom: '1rem', paddingBottom: '0.6rem', borderBottom: '1px solid var(--border-color)' }}>{title}</h3>
              {isText && <p style={{ fontSize: '0.92rem', color: 'var(--text-secondary)', lineHeight: '1.7', margin: 0 }}>{content}</p>}
            </div>
          ))}

          {/* Education */}
          <div style={{ backgroundColor: 'var(--bg-card)', borderRadius: '20px', border: '1px solid var(--border-color)', padding: '1.75rem' }}>
            <h3 style={{ fontSize: '1.1rem', fontWeight: 800, marginBottom: '1rem', paddingBottom: '0.6rem', borderBottom: '1px solid var(--border-color)' }}>Education & Qualifications</h3>
            <ul style={{ margin: 0, paddingLeft: '1.25rem', display: 'flex', flexDirection: 'column', gap: '0.5rem' }}>
              {meta.education.map((e: string, i: number) => <li key={i} style={{ fontSize: '0.9rem', color: 'var(--text-secondary)' }}>{e}</li>)}
            </ul>
          </div>

          {/* Certifications */}
          <div style={{ backgroundColor: 'var(--bg-card)', borderRadius: '20px', border: '1px solid var(--border-color)', padding: '1.75rem' }}>
            <h3 style={{ fontSize: '1.1rem', fontWeight: 800, marginBottom: '1rem', paddingBottom: '0.6rem', borderBottom: '1px solid var(--border-color)' }}>Certifications</h3>
            <ul style={{ margin: 0, paddingLeft: '1.25rem', display: 'flex', flexDirection: 'column', gap: '0.5rem' }}>
              {meta.certifications.map((c: string, i: number) => <li key={i} style={{ fontSize: '0.9rem', color: 'var(--text-secondary)' }}>{c}</li>)}
            </ul>
          </div>

          {/* Experience */}
          <div style={{ backgroundColor: 'var(--bg-card)', borderRadius: '20px', border: '1px solid var(--border-color)', padding: '1.75rem' }}>
            <h3 style={{ fontSize: '1.1rem', fontWeight: 800, marginBottom: '1rem', paddingBottom: '0.6rem', borderBottom: '1px solid var(--border-color)' }}>Professional Experience</h3>
            <ul style={{ margin: 0, paddingLeft: '1.25rem', display: 'flex', flexDirection: 'column', gap: '0.5rem' }}>
              {meta.experience_list.map((e: string, i: number) => <li key={i} style={{ fontSize: '0.9rem', color: 'var(--text-secondary)' }}>{e}</li>)}
            </ul>
          </div>

          {/* Awards */}
          <div style={{ backgroundColor: 'var(--bg-card)', borderRadius: '20px', border: '1px solid var(--border-color)', padding: '1.75rem' }}>
            <h3 style={{ fontSize: '1.1rem', fontWeight: 800, marginBottom: '1rem', paddingBottom: '0.6rem', borderBottom: '1px solid var(--border-color)' }}>Awards & Recognitions</h3>
            <ul style={{ margin: 0, paddingLeft: '1.25rem', display: 'flex', flexDirection: 'column', gap: '0.5rem' }}>
              {meta.awards.map((a: string, i: number) => <li key={i} style={{ fontSize: '0.9rem', color: 'var(--text-secondary)' }}>{a}</li>)}
            </ul>
          </div>

          {/* Patient Reviews */}
          <div style={{ backgroundColor: 'var(--bg-card)', borderRadius: '20px', border: '1px solid var(--border-color)', padding: '1.75rem' }}>
            <h3 style={{ fontSize: '1.1rem', fontWeight: 800, marginBottom: '1.25rem', paddingBottom: '0.6rem', borderBottom: '1px solid var(--border-color)' }}>Patient Reviews</h3>
            <div style={{ display: 'flex', flexDirection: 'column', gap: '1.25rem' }}>
              {meta.reviews.map((rev: any, i: number) => (
                <div key={i} style={{ borderBottom: i < meta.reviews.length - 1 ? '1px solid var(--border-color)' : 'none', paddingBottom: i < meta.reviews.length - 1 ? '1.25rem' : 0 }}>
                  <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '0.3rem' }}>
                    <strong style={{ fontSize: '0.92rem' }}>{rev.name}</strong>
                    <span style={{ fontSize: '0.82rem', color: '#d97706', fontWeight: 700 }}>⭐ {rev.rating}</span>
                  </div>
                  <span style={{ fontSize: '0.76rem', color: 'var(--text-muted)', display: 'block', marginBottom: '0.4rem' }}>Reviewed on {rev.date}</span>
                  <p style={{ margin: 0, fontSize: '0.88rem', color: 'var(--text-secondary)', lineHeight: '1.55' }}>"{rev.comment}"</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        {/* Right: Booking widget (sticky) */}
        <div style={{ display: 'flex', flexDirection: 'column', gap: '1.5rem' }}>
          <div style={{ backgroundColor: 'var(--bg-card)', borderRadius: '20px', border: '1px solid var(--border-color)', padding: '1.75rem', position: 'sticky', top: '90px' }}>
            <h3 style={{ fontSize: '1.1rem', fontWeight: 800, marginBottom: '1.25rem', paddingBottom: '0.6rem', borderBottom: '1px solid var(--border-color)' }}>Book a Consultation</h3>

            {bookingSuccess ? (
              <div style={{ textAlign: 'center', padding: '1.5rem 0' }}>
                <div style={{ width: '52px', height: '52px', borderRadius: '50%', backgroundColor: '#ecfdf5', color: '#10b981', display: 'flex', alignItems: 'center', justifyContent: 'center', margin: '0 auto 1rem' }}><Check size={28} /></div>
                <h4 style={{ fontWeight: 800 }}>Appointment Confirmed!</h4>
                <p style={{ fontSize: '0.85rem', color: 'var(--text-secondary)', marginTop: '0.4rem' }}>Present your booking at the clinic reception.</p>
                <button onClick={() => setBookingSuccess(false)} className="btn btn-primary" style={{ marginTop: '1.25rem', width: '100%', border: 'none', cursor: 'pointer' }}>Book Another</button>
              </div>
            ) : (
              <form onSubmit={handleBookingSubmit} style={{ display: 'flex', flexDirection: 'column', gap: '1.1rem' }}>
                {bookingError && <div className="alert alert-danger" style={{ fontSize: '0.84rem' }}>{bookingError}</div>}

                {/* Date picker */}
                <div className="form-group">
                  <label style={{ fontSize: '0.84rem', fontWeight: 600 }}>Select Date</label>
                  <div style={{ display: 'grid', gridTemplateColumns: 'repeat(4, 1fr)', gap: '0.4rem', marginTop: '0.5rem' }}>
                    {availableDays.map((d, idx) => {
                      const ds = d.toISOString().substring(0, 10);
                      const sel = selectedDateStr === ds;
                      return (
                        <button key={idx} type="button" onClick={() => setSelectedDateStr(ds)} style={{ padding: '0.5rem 0', borderRadius: '10px', border: sel ? '1px solid var(--accent-primary)' : '1px solid var(--border-color)', backgroundColor: sel ? 'var(--accent-primary)' : 'var(--bg-primary)', color: sel ? '#fff' : 'var(--text-primary)', cursor: 'pointer', textAlign: 'center' }}>
                          <div style={{ fontSize: '0.62rem', textTransform: 'uppercase', opacity: 0.7 }}>{d.toLocaleDateString(undefined, { weekday: 'short' })}</div>
                          <div style={{ fontSize: '1rem', fontWeight: 700 }}>{d.getDate()}</div>
                        </button>
                      );
                    })}
                  </div>
                </div>

                {/* Slot picker */}
                {selectedDateStr && (
                  <div className="form-group">
                    <label style={{ fontSize: '0.84rem', fontWeight: 600 }}>Available Slots</label>
                    {availableSlots.length === 0 ? (
                      <p style={{ fontSize: '0.8rem', color: 'var(--text-muted)', fontStyle: 'italic', marginTop: '0.4rem' }}>No slots on this date.</p>
                    ) : (
                      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: '0.4rem', marginTop: '0.5rem' }}>
                        {availableSlots.map((sl, i) => {
                          const sel = selectedSlot?.start === sl.start;
                          return <button key={i} type="button" onClick={() => setSelectedSlot(sl)} style={{ padding: '0.45rem 0', borderRadius: '8px', border: sel ? '1px solid var(--accent-primary)' : '1px solid var(--border-color)', backgroundColor: sel ? 'var(--accent-primary)' : 'var(--bg-primary)', color: sel ? '#fff' : 'var(--text-primary)', cursor: 'pointer', fontSize: '0.8rem', fontWeight: 700 }}>{sl.start}</button>;
                        })}
                      </div>
                    )}
                  </div>
                )}

                <AuthInput label="Patient Name *" icon={User} type="text" placeholder="Full Name" value={name} onChange={(e) => setName(e.target.value)} disabled={bookingLoading} required />
                <AuthInput label="Mobile *" icon={Phone} type="tel" placeholder="9546650878" value={phone} onChange={(e) => setPhone(e.target.value)} disabled={bookingLoading} required />

                <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '0.75rem' }}>
                  <AuthInput label="Date of Birth" icon={Calendar} type="date" value={dob} onChange={(e) => setDob(e.target.value)} disabled={bookingLoading} />
                  <div className="form-group">
                    <label>Gender</label>
                    <select value={gender} onChange={(e) => setGender(e.target.value)} disabled={bookingLoading} style={{ width: '100%', padding: '0.7rem', border: '1px solid var(--border-color)', borderRadius: '12px', backgroundColor: 'var(--bg-card)', color: 'var(--text-primary)', outline: 'none', marginTop: '0.4rem' }}>
                      <option value="Male">Male</option>
                      <option value="Female">Female</option>
                      <option value="Other">Other</option>
                    </select>
                  </div>
                </div>

                <div className="form-group">
                  <label>Symptoms / Notes</label>
                  <textarea value={notes} onChange={(e) => setNotes(e.target.value)} rows={2} disabled={bookingLoading} placeholder="Describe symptoms…" style={{ width: '100%', padding: '0.7rem', border: '1px solid var(--border-color)', borderRadius: '12px', backgroundColor: 'var(--bg-card)', color: 'var(--text-primary)', outline: 'none', resize: 'vertical', marginTop: '0.4rem' }} />
                </div>

                <AuthButton type="submit" loading={bookingLoading} loadingText="Confirming…">
                  Book Consultation (₹590 incl. GST)
                </AuthButton>
              </form>
            )}
          </div>

          {/* Clinic location card */}
          <div style={{ backgroundColor: 'var(--bg-card)', borderRadius: '20px', border: '1px solid var(--border-color)', padding: '1.75rem' }}>
            <h3 style={{ fontSize: '1rem', fontWeight: 800, marginBottom: '1rem', paddingBottom: '0.6rem', borderBottom: '1px solid var(--border-color)' }}>Clinic Location</h3>
            <div style={{ display: 'flex', flexDirection: 'column', gap: '0.7rem', fontSize: '0.88rem', color: 'var(--text-secondary)' }}>
              <div style={{ display: 'flex', gap: '0.5rem' }}>
                <MapPin size={16} style={{ color: 'var(--accent-primary)', flexShrink: 0, marginTop: '2px' }} />
                <span>{meta.address}</span>
              </div>
              <div style={{ display: 'flex', gap: '0.5rem' }}>
                <Phone size={16} style={{ color: 'var(--accent-primary)', flexShrink: 0, marginTop: '2px' }} />
                <span>+91 {meta.phone}</span>
              </div>
              <div style={{ display: 'flex', gap: '0.5rem' }}>
                <Globe size={16} style={{ color: 'var(--accent-primary)', flexShrink: 0, marginTop: '2px' }} />
                <span>Languages: {meta.languages.join(', ')}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
};

// ─── 5. DEPARTMENTS ───────────────────────────────────────────────────────────

export const PublicDepartments: React.FC = () => {
  useEffect(() => { document.title = 'Departments – Aura Healthcare Clinics'; }, []);
  const depts = [
    { title: 'General Medicine', desc: 'Outpatient consultations, chronic disease management, preventive screening, and family medicine.', icon: Shield, color: '#4f46e5' },
    { title: 'Cardiology', desc: 'Coronary monitoring, ECG scans, blood pressure audits, heart failure screening, and rehabilitation.', icon: Heart, color: '#ef4444' },
    { title: 'Neurology', desc: 'Brain stroke treatment, migraine management, nerve pain audits, and cognitive assessments.', icon: Activity, color: '#8b5cf6' },
    { title: 'Pediatrics', desc: 'Child wellness checks, infant vaccinations, growth monitoring, and neonatal care.', icon: Users, color: '#06b6d4' },
  ];
  return (
    <div style={{ padding: '4rem 2rem', maxWidth: '1100px', margin: '0 auto' }}>
      <div style={{ textAlign: 'center', marginBottom: '3.5rem' }}>
        <span style={{ color: 'var(--accent-primary)', fontWeight: 700, textTransform: 'uppercase', letterSpacing: '1px', fontSize: '0.85rem' }}>OUR MEDICAL WARDS</span>
        <h1 style={{ fontFamily: 'var(--font-heading)', fontSize: '2.5rem', fontWeight: 800, marginTop: '0.5rem' }}>Clinical Departments</h1>
      </div>
      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(260px, 1fr))', gap: '2rem' }}>
        {depts.map((d, i) => {
          const Icon = d.icon;
          return (
            <div key={i} className="dashboard-card" style={{ padding: '2rem', borderRadius: '20px', display: 'flex', flexDirection: 'column', gap: '1rem' }}>
              <div style={{ width: '52px', height: '52px', borderRadius: '14px', backgroundColor: `${d.color}14`, display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
                <Icon size={26} color={d.color} />
              </div>
              <h3 style={{ fontSize: '1.2rem', fontWeight: 700 }}>{d.title}</h3>
              <p style={{ fontSize: '0.9rem', color: 'var(--text-secondary)', lineHeight: '1.65', margin: 0 }}>{d.desc}</p>
            </div>
          );
        })}
      </div>
    </div>
  );
};

